<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.lrec.operator">

    <!-- ── أذونات التخزين ────────────────────────────────────────── -->
    <!-- Android 5 - 12 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.LRECOperator">

        <!-- ── شاشة البداية ──────────────────────────────────── -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.LRECOperator.NoActionBar">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ── المشغل الرئيسي للفيديو العادي ────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="sensorLandscape" />

        <!-- ── مكتبة الفيديو ──────────────────────────────────── -->
        <activity
            android:name=".VideoLibraryActivity"
            android:exported="false" />

        <!-- ── الإعدادات ──────────────────────────────────────── -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- ── مشغّل ملفات .lrec ─────────────────────────────── -->
        <!--
            exported=true مطلوب لكي يفتح مدير الملفات هذا المشغّل مباشرةً.
            configChanges تمنع إعادة إنشاء الـ Activity عند تدوير الشاشة أو تغيير لوحة المفاتيح.
        -->
        <activity
            android:name=".LrecPlayerActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="sensorLandscape">

            <!-- ✅ فتح ملفات .lrec مباشرةً من مدير الملفات -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- النوع العام لملفات غير معروفة -->
                <data android:mimeType="application/octet-stream" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- النوع المخصص لـ .lrec -->
                <data android:mimeType="application/x-lrec" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- احتياطي: أي ملف -->
                <data android:mimeType="*/*" />
            </intent-filter>

        </activity>

        <!-- ── مزوّد FileProvider لمشاركة الملفات بأمان ─────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
