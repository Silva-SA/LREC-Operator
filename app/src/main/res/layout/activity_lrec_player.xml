<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ══════════════════════════════════════════════════════════
         منطقة عرض الشاشة الرئيسية
         ════════════════════════════════════════════════════════ -->
    <ImageView
        android:id="@+id/imageViewScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:background="#000000"
        android:contentDescription="@string/app_name" />

    <!-- تدرج سفلي يجعل أزرار التحكم مقروءة فوق أي محتوى -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom" />

    <!-- ══════════════════════════════════════════════════════════
         شريط العنوان العلوي
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@drawable/gradient_top">

        <!-- زر الرجوع -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/btn_icon_ripple"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="رجوع" />

        <!-- معلومات الملف -->
        <TextView
            android:id="@+id/tvFrameInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#DDFFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="جارٍ التحميل…" />

        <!-- حالة الصوت -->
        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:text="" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         لوحة التحكم السفلية
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- ── صف الوقت ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ── شريط التقدم ─────────────────────────────── -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:thumbTint="#FFFFFFFF"
            android:progressTint="#FFFFFFFF"
            android:progressBackgroundTint="#44FFFFFF"
            android:max="1000"
            android:enabled="false" />

        <!-- ── أزرار التحكم ────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <!-- ترجيع 10 ثوانٍ -->
            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_rewind"
                android:background="@drawable/btn_control_ripple"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:enabled="false"
                android:contentDescription="ترجيع 10 ثوانٍ" />

            <!-- تشغيل -->
            <ImageButton
                android:id="@+id/btnPlay"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_play_button"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:enabled="false"
                android:contentDescription="تشغيل" />

            <!-- إيقاف مؤقت -->
            <ImageButton
                android:id="@+id/btnPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_pause"
                android:background="@drawable/bg_play_button"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:enabled="false"
                android:contentDescription="إيقاف مؤقت" />

            <!-- إعادة من البداية -->
            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/btn_control_ripple"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:enabled="false"
                android:contentDescription="إعادة من البداية" />

            <!-- تقديم 10 ثوانٍ -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_forward"
                android:background="@drawable/btn_control_ripple"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:enabled="false"
                android:contentDescription="تقديم 10 ثوانٍ" />

        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         شاشة التحميل (تُغطي كل شيء أثناء المعالجة)
         ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#DD000000"
        android:visibility="visible">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="#FFFFFFFF" />

        <TextView
            android:id="@+id/tvLoadingMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="جارٍ تحليل الملف…"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
