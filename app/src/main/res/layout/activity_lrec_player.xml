<?xml version="1.0" encoding="utf-8"?>
<!--
    ════════════════════════════════════════════════════════════
     activity_lrec_player.xml — واجهة مشغّل ملفات .lrec
     مع: زر تشغيل/إيقاف + ترجيع + تقديم + شريط تقدم + وقت
    ════════════════════════════════════════════════════════════
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ══ منطقة عرض الفيديو (الإطارات كـ Bitmap) ══════════════ -->
    <ImageView
        android:id="@+id/lrecImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:background="@android:color/black"
        android:contentDescription="شاشة الفيديو" />

    <!-- ══ مؤشر التحميل ══════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/lrecProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- ══ نص الحالة (عدد الإطارات / خطأ) ══════════════════════ -->
    <TextView
        android:id="@+id/lrecTvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="170dp"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:background="#88000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- ══ تدرج علوي (يجعل النص مقروءاً على الفيديو) ═══════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/gradient_top" />

    <!-- ══ شريط علوي: زر رجوع + عنوان + زر معلومات ════════════ -->
    <LinearLayout
        android:id="@+id/lrecTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <!-- زر الرجوع -->
        <ImageButton
            android:id="@+id/lrecBtnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/btn_icon_ripple"
            android:padding="11dp"
            android:contentDescription="رجوع" />

        <!-- عنوان الملف -->
        <TextView
            android:id="@+id/lrecTvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:shadowColor="#AA000000"
            android:shadowRadius="3"
            android:text="…" />

        <!-- زر المعلومات -->
        <ImageButton
            android:id="@+id/lrecBtnInfo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/btn_icon_ripple"
            android:padding="11dp"
            android:contentDescription="معلومات الملف" />

    </LinearLayout>

    <!-- ══ تدرج سفلي ════════════════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom" />

    <!-- ══ شريط التحكم السفلي ═══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lrecPlayerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <!-- صف الوقت (يسار = وقت حالي | يمين = المدة الكلية) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/lrecTvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- مسافة مرنة -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/lrecTvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- شريط التقدم -->
        <SeekBar
            android:id="@+id/lrecSeekBar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:progressTint="@color/accent_blue"
            android:progressBackgroundTint="#55FFFFFF"
            android:thumbTint="@android:color/white"
            android:splitTrack="false"
            android:max="1000"
            android:progress="0" />

        <!-- صف أزرار التحكم (ترجيع + تشغيل/إيقاف + تقديم) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <!-- ترجيع 10 ثوانٍ -->
            <ImageButton
                android:id="@+id/lrecBtnRewind"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_rewind"
                android:background="@drawable/btn_control_ripple"
                android:padding="11dp"
                android:contentDescription="ترجيع 10 ثوانٍ"
                android:enabled="false"
                android:alpha="0.5" />

            <!-- تشغيل / إيقاف مؤقت -->
            <ImageButton
                android:id="@+id/lrecBtnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_play_button"
                android:padding="14dp"
                android:contentDescription="تشغيل / إيقاف مؤقت"
                android:enabled="false"
                android:alpha="0.5" />

            <!-- تقديم 10 ثوانٍ -->
            <ImageButton
                android:id="@+id/lrecBtnForward"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_forward"
                android:background="@drawable/btn_control_ripple"
                android:padding="11dp"
                android:contentDescription="تقديم 10 ثوانٍ"
                android:enabled="false"
                android:alpha="0.5" />

        </LinearLayout>

        <!-- شريط معلومات الصوت والشات (تنبيه التشفير) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔇  الصوت: مشفَّر"
                android:textColor="#FFCC44"
                android:textSize="11sp"
                android:background="#77000000"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <View
                android:layout_width="14dp"
                android:layout_height="1dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬  الشات: مشفَّر"
                android:textColor="#FFCC44"
                android:textSize="11sp"
                android:background="#77000000"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
