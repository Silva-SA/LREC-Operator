<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_lrec_player.xml
    واجهة مشغل ملفات .lrec
    - SurfaceView لعرض الشاشة المُسجَّلة
    - Overlay شفاف للمحادثة (يسار)
    - أدوات التحكم في الأسفل
    - شريط العنوان في الأعلى
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  منطقة عرض الشاشة المُسجَّلة                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <SurfaceView
        android:id="@+id/lrecSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"/>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  شاشة التحميل (تظهر أثناء التحليل)                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="visible">

        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:id="@+id/tvLoadingMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="جاري تحليل الملف..."
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-light"/>

        <TextView
            android:id="@+id/tvLoadingDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  Overlay المحادثة (يظهر بالضغط على زر Chat)               -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/chatOverlay"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#CC1A1A2E"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- عنوان الـ Chat -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="💬  المحادثة"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#33FFFFFF"/>

            <!-- قائمة الرسائل -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clipToPadding="false"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  Overlays الصوت والسطوع (نفس نمط MainActivity)            -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lrecVolumeOverlay"
        android:layout_width="52dp"
        android:layout_height="190dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_overlay_pill"
        android:visibility="invisible"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_volume"
            android:tint="#FFFFFF"/>

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="110dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_track"/>
            <View
                android:id="@+id/lrecVolumeBar"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_progress_fill"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvLrecVolumePercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="70%"
            android:textColor="#FFFFFF"
            android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/lrecBrightnessOverlay"
        android:layout_width="52dp"
        android:layout_height="190dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_overlay_pill"
        android:visibility="invisible"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_brightness"
            android:tint="#FFFFFF"/>

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="110dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_track"/>
            <View
                android:id="@+id/lrecBrightnessBar"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_progress_fill_brightness"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvLrecBrightnessPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="70%"
            android:textColor="#FFFFFF"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  الشريط العلوي                                             -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lrecTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:background="@drawable/gradient_top">

        <!-- زر الرجوع -->
        <ImageButton
            android:id="@+id/lrecBtnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:background="@drawable/btn_icon_ripple"
            android:padding="10dp"
            android:contentDescription="رجوع"/>

        <!-- عنوان الملف -->
        <TextView
            android:id="@+id/lrecTvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:text="محاضرة .lrec"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textStyle="bold"/>

        <!-- زر المحادثة -->
        <ImageButton
            android:id="@+id/lrecBtnChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:tint="#FFFFFF"
            android:background="@drawable/btn_icon_ripple"
            android:padding="9dp"
            android:contentDescription="عرض المحادثة"/>

        <!-- زر التدوير -->
        <ImageButton
            android:id="@+id/lrecBtnRotate"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_rotate"
            android:tint="#FFFFFF"
            android:background="@drawable/btn_icon_ripple"
            android:padding="9dp"
            android:contentDescription="تدوير الشاشة"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  أدوات التحكم السفلية                                      -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lrecPlayerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="8dp"
        android:background="@drawable/gradient_bottom">

        <!-- شريط التقدم -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginBottom="4dp">

            <!-- المسار الرمادي -->
            <View
                android:id="@+id/lrecProgressTrack"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_progress_track"/>

            <!-- التعبئة الملونة -->
            <View
                android:id="@+id/lrecProgressFill"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:layout_gravity="center_vertical|start"
                android:background="@drawable/bg_progress_fill"/>

            <!-- الـ Thumb -->
            <View
                android:id="@+id/lrecProgressThumb"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center_vertical|start"
                android:background="@drawable/bg_seekbar_thumb"/>

            <!-- SeekBar شفاف للتفاعل -->
            <SeekBar
                android:id="@+id/lrecSeekBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@android:color/transparent"
                android:thumb="@android:color/transparent"
                android:max="1000"
                android:splitTrack="false"/>
        </FrameLayout>

        <!-- الأزرار والأوقات -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- الوقت الحالي -->
            <TextView
                android:id="@+id/lrecTvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:minWidth="44dp"/>

            <!-- فاصل -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Rewind 10s -->
            <ImageButton
                android:id="@+id/lrecBtnRewind"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_rewind"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_control_ripple"
                android:padding="10dp"/>

            <!-- Play/Pause -->
            <ImageButton
                android:id="@+id/lrecBtnPlayPause"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_play"
                android:tint="#FFFFFF"
                android:background="@drawable/bg_play_button"
                android:padding="12dp"/>

            <!-- Forward 10s -->
            <ImageButton
                android:id="@+id/lrecBtnForward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_forward"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_control_ripple"
                android:padding="10dp"/>

            <!-- فاصل -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- المدة الكلية -->
            <TextView
                android:id="@+id/lrecTvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:minWidth="44dp"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  رسالة الخطأ (تظهر عند فشل القراءة)                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#DD000000"
        android:visibility="gone"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="40sp"/>

        <TextView
            android:id="@+id/tvErrorMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="تعذّر قراءة الملف"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvErrorDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:gravity="center"/>
    </LinearLayout>

</FrameLayout>
