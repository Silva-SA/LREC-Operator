<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/splash_bg">

    <!-- أيقونة التطبيق -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@mipmap/ic_launcher_round"
        android:layout_marginBottom="24dp"/>

    <!-- اسم المطور -->
    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Silva.SA"
        android:textColor="@color/splash_brand"
        android:textSize="32sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:layout_marginBottom="32dp"/>

    <!-- رسالة الترحيب -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        android:text="لأن وقتكم مهم بالنسبة لكم\nولأن أبرز خطواتنا تنجز بالتراكم\nنقولها لكم حملها وشغلها\n\n          ^_^\n\nهذا المنتج مصمم للاستخدام الشخصي\nويمنع استخدامه للأغراض التجارية أو النشر\nدون موافقة مسبقة\n\nاحترم جهدنا"
        android:textColor="@color/splash_text"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.6"
        android:gravity="center"
        android:background="@drawable/bg_splash_card"
        android:padding="20dp"
        android:layout_marginBottom="36dp"/>

    <!-- زر الدخول -->
    <Button
        android:id="@+id/btnEnter"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:visibility="invisible"
        android:text="ابدأ الآن"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_enter"
        android:stateListAnimator="@null"/>

</LinearLayout>
